# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# ── OpenHAB Server ───────────────────────────────────────────────
OPENHAB_HOST=192.168.x.x
OPENHAB_SSH_USER=openhabian
OPENHAB_CONFIG_PATH=/etc/openhab
OPENHAB_SCRIPTS_PATH=/opt/openhab-scripts
# Optional: path to SSH private key (leave empty to use default ~/.ssh/id_rsa)
OPENHAB_SSH_KEY=
# Set to true if your SSH user needs sudo to write to OPENHAB_CONFIG_PATH (/etc/openhab)
# Requires one-time setup on the server:
#   echo "$USER ALL=(ALL) NOPASSWD: /usr/bin/rsync" | sudo tee /etc/sudoers.d/rsync-deploy
OPENHAB_SUDO_RSYNC=false

# ── MQTT Broker ──────────────────────────────────────────────────
MQTT_HOST=10.1.0.10
MQTT_USERNAME=MQTTuser
MQTT_PASSWORD=your_mqtt_password_here

# ── OpenWeatherMap ───────────────────────────────────────────────
OWM_API_KEY=your_openweathermap_api_key_here

# ── Telegram Bots ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_CHAT_ID=your_chat_id_here
TELEGRAM_WASHBOT_TOKEN=your_washbot_token_here
TELEGRAM_WASHBOT_CHAT_ID=your_washbot_chat_id_here

# ── Reolink Cameras (via NVR) ────────────────────────────────────
CAMERA_NVR_IP=10.1.2.1
CAMERA_USERNAME=admin
CAMERA_PASSWORD=your_camera_password_here
