
rule "BreakfastSun"
when
    Item Kitchen_Rollershutter_SunProtect changed 

then
    logInfo("BreakfastSun", "Trigger: Breakfast Sun")

    if (Kitchen_Rollershutter_SunProtect.state == ON) {
        logInfo("BreakfastSun", "Lower the Blinds")
        // TEst Office_Herwig_Rollershutter.sendCommand("50")
        DiningRoom_Rollershutter_SidesRight.sendCommand("40")
        DiningRoom_Rollershutter_SidesLeft.sendCommand("40")
        DiningRoom_Rollershutter_Exit.sendCommand("40")
        Kitchen_Rollershutter.sendCommand("50")
        DiningRoom_Rollershutter_SidesRight_Tilt.sendCommand("60")
        DiningRoom_Rollershutter_SidesLeft_Tilt.sendCommand("60")
        DiningRoom_Rollershutter_Exit_Tilt.sendCommand("60")
        Kitchen_Rollershutter_Tilt.sendCommand("60")
    } 
    else {
        logInfo("BreakfastSun", "Lift the Blinds")
        // Test Office_Herwig_Rollershutter.sendCommand("0")
        DiningRoom_Rollershutter_SidesRight_Tilt.sendCommand("0")
        DiningRoom_Rollershutter_SidesLeft_Tilt.sendCommand("0")
        DiningRoom_Rollershutter_Exit_Tilt.sendCommand("0")
        Kitchen_Rollershutter_Tilt.sendCommand("0")
        DiningRoom_Rollershutter_SidesLeft.sendCommand("0")
        DiningRoom_Rollershutter_SidesRight.sendCommand("0")
        DiningRoom_Rollershutter_Exit.sendCommand("0")
        Kitchen_Rollershutter.sendCommand("0")

    }
end



rule "NightPrivacy"
when
//    Item Rollershutter_Privacy changed or 
    Item Strasshof_Privacy changed
then
    logInfo("NightPrivacy", "Trigger: Night Privacy")

//    if (Rollershutter_Strasshof_Privacy.state == ON) {
    if (Strasshof_Privacy.state == ON) {
        logInfo("NightPrivacy", "Lower the Blinds")
        // TEst Office_Herwig_Rollershutter.sendCommand("50")

        DiningRoom_Rollershutter_SidesRight_Tilt.sendCommand("70")
        DiningRoom_Rollershutter_SidesLeft_Tilt.sendCommand("70")
        DiningRoom_Rollershutter_Exit_Tilt.sendCommand("70")
        Livingroom_Rollershutter_Tilt.sendCommand("80")
        Kitchen_Rollershutter_Tilt.sendCommand("70")
        DiningRoom_Rollershutter_SidesRight.sendCommand("100")
        DiningRoom_Rollershutter_SidesLeft.sendCommand("100")
        DiningRoom_Rollershutter_Exit.sendCommand("100")
        Livingroom_Rollershutter.sendCommand("100")
        Kitchen_Rollershutter.sendCommand("90")
    } 
    else {
        logInfo("NightPrivacy", "Lift the Blinds")
        // Test Office_Herwig_Rollershutter.sendCommand("0")
        DiningRoom_Rollershutter_SidesRight_Tilt.sendCommand("0")
        DiningRoom_Rollershutter_SidesLeft_Tilt.sendCommand("0")
        DiningRoom_Rollershutter_Exit_Tilt.sendCommand("0")
        Livingroom_Rollershutter_Tilt.sendCommand("0")
        Kitchen_Rollershutter_Tilt.sendCommand("0")
        Livingroom_Rollershutter.sendCommand("0")
        DiningRoom_Rollershutter_SidesLeft.sendCommand("0")
        DiningRoom_Rollershutter_SidesRight.sendCommand("0")
        DiningRoom_Rollershutter_Exit.sendCommand("0")
        Kitchen_Rollershutter.sendCommand("0")


    }
end

// Move Rollershutter to top in case tilt was not set
rule "Top up Rollershutter Kitchen"
when 
    Item Kitchen_Rollershutter changed
then
    val opening = Kitchen_Rollershutter.state
    val tilt = Kitchen_Rollershutter_Tilt.state
    //logInfo("top_up_kitchen", "Trigger: move_to_top_kitchen changed to {}%. Tilt: {}%.}", opening, tilt)
    if (opening == 0 && tilt != 0) {
       logInfo("top_up_rollershutter", "Trigger: Rollershutter Kitchen reached 0 therefor setting tilt to 0 too.", opening)
       Kitchen_Rollershutter_Tilt.sendCommand("0") 
    }
end



