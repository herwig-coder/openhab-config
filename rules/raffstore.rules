rule "NightPrivacy"
when
    Item Strasshof_Privacy changed
then
    if (Strasshof_Privacy.state == NULL || Strasshof_Privacy.state == UNDEF) return;

    // Cancel any pending tilt timer from a previous (possibly interrupted) run
    if (NightPrivacy_TiltTimer !== null) {
        NightPrivacy_TiltTimer.cancel()
        NightPrivacy_TiltTimer = null
    }

    if (Strasshof_Privacy.state == ON) {
        logInfo("NightPrivacy", "Lower the Blinds — sending position commands")

        // 1. Send position commands first
        DiningRoom_Rollershutter_SidesRight.sendCommand("100")
        DiningRoom_Rollershutter_SidesLeft.sendCommand("100")
        DiningRoom_Rollershutter_Exit.sendCommand("100")
        Livingroom_Rollershutter.sendCommand("100")
        Kitchen_Rollershutter.sendCommand("90")

        // 2. After blinds have had time to reach position, apply tilt
        NightPrivacy_TiltTimer = createTimer(now.plusSeconds(25)) [ |
            logInfo("NightPrivacy", "Applying tilt after position settled")
            DiningRoom_Rollershutter_SidesRight_Tilt.sendCommand("70")
            DiningRoom_Rollershutter_SidesLeft_Tilt.sendCommand("70")
            DiningRoom_Rollershutter_Exit_Tilt.sendCommand("70")
            Livingroom_Rollershutter_Tilt.sendCommand("80")
            Kitchen_Rollershutter_Tilt.sendCommand("70")
            NightPrivacy_TiltTimer = null
        ]
    } else {
        logInfo("NightPrivacy", "Lift the Blinds")
        DiningRoom_Rollershutter_SidesRight_Tilt.sendCommand("0")
        DiningRoom_Rollershutter_SidesLeft_Tilt.sendCommand("0")
        DiningRoom_Rollershutter_Exit_Tilt.sendCommand("0")
        Livingroom_Rollershutter_Tilt.sendCommand("0")
        Kitchen_Rollershutter_Tilt.sendCommand("0")
        Livingroom_Rollershutter.sendCommand("0")
        DiningRoom_Rollershutter_SidesLeft.sendCommand("0")
        DiningRoom_Rollershutter_SidesRight.sendCommand("0")
        DiningRoom_Rollershutter_Exit.sendCommand("0")
        Kitchen_Rollershutter.sendCommand("0")
    }
end

