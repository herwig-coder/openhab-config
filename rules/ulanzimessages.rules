rule "ulanzistrompreis"
when
    Item Awattar_Price_CurrentNet changed
then
    logInfo("ulanzistrompreis", "Trigger: strompreis changed")

    // NULL guard - CRITICAL
    if (Awattar_Price_CurrentNet.state == NULL || Awattar_Price_CurrentNet.state == UNDEF) {
        logWarn("ulanzistrompreis", "Awattar_Price_CurrentNet is NULL/UNDEF, skipping")
        return;
    }

    val netprice = (Awattar_Price_CurrentNet.state as QuantityType<Number>).doubleValue
    logInfo("ulanzistrompreis", "Awattar Preis netto: {} ct/kWh", String.format("%.2f",netprice))
    // include 3% exchange fee. 1.5 ct Awattar fee + 0.78 net cost + 0.1 ct net loss cost
    //2025
    // 1.03 factor Awattar
    // 1.5 ct Awattar
    // 8.2 Netznutzungsentgelt
    // 0.45 Netzverlustentgelt
    // 1.5 ct elektrizitätsabgabe
    // 0.8 ct Ökostromfürderbeitrag 0.74 + 0.04
    val grossprice = (netprice * 1.03 + 1.5 + 8.2 + 0.45 + 1.5 + 0.8) * 1.2
    logInfo("ulanzistrompreis", "Awattar Preis gesamt: {} ct/kWh", String.format("%.2f",grossprice))
    Awattar_Price_Total.postUpdate(grossprice)

    //default yellow
    var color = "#FFDE21"
    if (grossprice > 30) {
        // price high red
        color = "#FF0000"
    }
    if (grossprice < 24) {
         // price low green
        color = "#00FF00"
    }
    //JSON {"preis","color":"#00FF00","icon":"5370"}
    val message = "{\"text\": \"" + String.format("%.2f",grossprice) + "\", \"color\":\"" + color + "\" ,\"icon\":\"53070\"}"
    logInfo("ulanzistrompreis", "send to Ulanzi: {}", message)
    logInfo("ulanzi_strom", "Composed the following message: " + message)
    Ulanzi_PowerPrice.sendCommand(message)
end


rule "ulanzi_airing"
when
    Item Bathroom_DewPoint_Alert changed or
    Item ParentsBedroom_DewPoint_Alert changed or
    Item ChildrenBedroom_DewPoint changed
then
    logInfo("ulanzi_airing", "Trigger: Dewpoint Alert status has changed")

    // NULL guards for all items
    if (Bathroom_DewPoint_Alert.state == NULL || Bathroom_DewPoint_Alert.state == UNDEF) {
        logWarn("ulanzi_airing", "Bathroom_DewPoint_Alert is NULL/UNDEF")
        return;
    }
    if (ParentsBedroom_DewPoint_Alert.state == NULL || ParentsBedroom_DewPoint_Alert.state == UNDEF) {
        logWarn("ulanzi_airing", "ParentsBedroom_DewPoint_Alert is NULL/UNDEF")
        return;
    }
    if (ChildrenBedroom_DewPoint.state == NULL || ChildrenBedroom_DewPoint.state == UNDEF) {
        logWarn("ulanzi_airing", "ChildrenBedroom_DewPoint is NULL/UNDEF")
        return;
    }

    var msg = ""
    if (Bathroom_DewPoint_Alert.state == ON) {
        msg = msg + "Badezimmer "
    }
    if (ParentsBedroom_DewPoint_Alert.state == ON) {
        msg = msg + "Schalfzimmer "
    }
    if (ChildrenBedroom_DewPoint.state == ON) {
       msg = msg + "Tommy Zimmer"
    }
    logInfo("ulanzi_airing", "Composed message: {}", msg)
    if (msg != "") {
        //default red
        val color = "#FF0000"
        //JSON {"msg","color":"#00FF00","icon":"32097"} Lametric icon for open window
        msg = "{\"text\":\"" + msg + "\",\"color\":\"" + color + "\",\"icon\":\"32097\"}"
        logInfo("ulanzi_airing", "send to Ulanzi: {}", msg)
        Ulanzi_VentilationAlert.sendCommand(msg)
    }
    else {
        Ulanzi_VentilationAlert.sendCommand("")
    }
end

rule "ulanzi_muellmessage"
when
    Item Garbage_NextCollection changed
    //Time cron "1 0 * ? * * *"
then
    // get value in Java ZonedDateTime
    val currenttime = now
    logInfo("ulanzi_muell", "Trigger every 1 hour and 1 second: " + currenttime)

    // NULL guard - CRITICAL
    if (Garbage_NextCollection.state == NULL || Garbage_NextCollection.state == UNDEF) {
        // clear ulanzi
        Ulanzi_GarbageAlert.sendCommand("")
        Garbage_Collection_Message.sendCommand(muellmessage)
        logWarn("ulanzi_muell", "Clear Message and skip the rest Garbage_NextCollection is NULL/UNDEF, skipping")
        return;
    }

    // get value in Java ZonedDateTime
    var muellmessage = ""
    val collectiondate = (Garbage_NextCollection.state as DateTimeType).getZonedDateTime(ZoneId.systemDefault())
    logInfo("ulanzi_muell", "Next CollectionDate: " + collectiondate)
    // get remaining hours in Type Duration
    val Duration timeuntilcollection = Duration.between(currenttime, collectiondate)
    //logInfo("ulanzi_muell", "Duration : " + timeuntilcollection)
    logInfo("ulanzi_muell", "Time until next collection in hours: " + timeuntilcollection.getSeconds()/3600)
    // collection within 24 hours

    if (timeuntilcollection.getSeconds()/3600 <= 24) {
        if (currenttime.toLocalDate == collectiondate.toLocalDate) {
            muellmessage = "Heute: "
        }
        else {
            muellmessage = "Morgen: "
        }
    } else if (timeuntilcollection.getSeconds()/3600 > 24) {
        //val date_formatter = java.time.format.DateTimeFormatter.ofPattern("%ta %1$td.%1$tm", java.util.Locale.GERMAN)
        muellmessage = String.format(java.util.Locale.GERMAN,"%ta %1$td.%1$tm",collectiondate.toLocalDate()) + ": "

        logInfo("ulanzi_muell", "Message" + muellmessage)
    }

    // NULL guard for Garbage_Collection_Item0
    if (Garbage_Collection_Item0.state != NULL && Garbage_Collection_Item0.state != UNDEF) {
        if (Garbage_Collection_Item0.state.equals("Restmüll")) {
            muellmessage = muellmessage + "Restmuell"
            logInfo("ulanzi_muell", "Changed " + Garbage_Collection_Item0.state + " to Restmuell")
        }
        else {
            muellmessage = muellmessage + Garbage_Collection_Item0.state
        }
    }

    // NULL guard for Garbage_Collection_Item1
    if (Garbage_Collection_Item1.state != NULL && Garbage_Collection_Item1.state != UNDEF &&
        Garbage_NextCollection_1.state != NULL && Garbage_NextCollection_1.state != UNDEF &&
        Garbage_NextCollection.state == Garbage_NextCollection_1.state) {
        if (Garbage_Collection_Item1.state.equals("Restmüll")) {
            muellmessage = muellmessage + ", Restmuell"
            logInfo("ulanzi_muell", "Changed " + Garbage_Collection_Item1.state + " to Restmuell")
        }
        else {
            muellmessage = muellmessage + ", " + Garbage_Collection_Item1.state
        }
    }

    // NULL guard for Garbage_Collection_Item2
    if (Garbage_Collection_Item2.state != NULL && Garbage_Collection_Item2.state != UNDEF &&
        Garbage_NextCollection_2.state != NULL && Garbage_NextCollection_2.state != UNDEF &&
        Garbage_NextCollection.state == Garbage_NextCollection_2.state) {
        if (Garbage_Collection_Item2.state.equals("Restmüll")) {
            muellmessage = muellmessage + ", Restmuell"
            logInfo("ulanzi_muell", "Changed " + Garbage_Collection_Item2.state + " to Restmuell")
        }
        else {
            muellmessage = muellmessage + ", " + Garbage_Collection_Item2.state
        }
    }

    // NULL guard for Garbage_Collection_Item3
    if (Garbage_Collection_Item3.state != NULL && Garbage_Collection_Item3.state != UNDEF &&
        Garbage_NextCollection_3.state != NULL && Garbage_NextCollection_3.state != UNDEF &&
        Garbage_NextCollection.state == Garbage_NextCollection_3.state) {
        if (Garbage_Collection_Item3.state.equals("Restmüll")) {
            muellmessage = muellmessage + ", Restmuell"
            logInfo("ulanzi_muell", "Changed " + Garbage_Collection_Item3.state + " to Restmuell")
        }
        else {
            muellmessage = muellmessage + ", " + Garbage_Collection_Item3.state
        }
    }

    if (muellmessage != "") {
        logInfo("ulanzi_muell", "Composed the following message: " + muellmessage)
        Corridor_Message.sendCommand(muellmessage)
        Garbage_Collection_Message.sendCommand(muellmessage)
        // Send message to Ulanzi {"text":"%s","color": "#00FF00" }
        val color = "#00FF00"
        Ulanzi_GarbageAlert.sendCommand("{\"text\":\"" + muellmessage + "\",\"color\":\"" + color + "\",\"icon\":\"53860\"}")
    }
    else {
        // clear ulanzi
        Ulanzi_GarbageAlert.sendCommand("")
        Garbage_Collection_Message.sendCommand(muellmessage)
    }
end

// Ulanzi Traincheck
rule "ulanzi_train check on"
when
    Time cron "0 20 7 ? * MON-FRI *"
then
    logInfo("ulanzi_train", "Traincheck on.")
    Ulanzi_TrainCheck.sendCommand(ON)
end

rule "ulanzi_train check off"
when
    Time cron "0 50 7 ? * MON-FRI *"
then
    logInfo("ulanzi_train", "Traincheck off.")
    Ulanzi_TrainCheck.sendCommand(OFF)
    Ulanzi_Train.sendCommand("")
end

rule "ulanzi_train message"
when
    Item TrainStatus_Text changed or
    Item TrainDelay_Minutes changed or
    Item Ulanzi_TrainCheck changed
then
    // NULL guard for traincheck
    if (Ulanzi_TrainCheck.state == NULL || Ulanzi_TrainCheck.state == UNDEF) {
        logWarn("ulanzi_train", "Ulanzi_TrainCheck is NULL/UNDEF")
        return;
    }

    if (Ulanzi_TrainCheck.state == ON) {
        logInfo("ulanzi_train", "Trainmessage update.")

        // NULL guards for train data
        if (TrainDeparture_Time.state == NULL || TrainDeparture_Time.state == UNDEF) {
            logWarn("ulanzi_train", "TrainDeparture_Time is NULL/UNDEF")
            return;
        }
        if (TrainStatus_Text.state == NULL || TrainStatus_Text.state == UNDEF) {
            logWarn("ulanzi_train", "TrainStatus_Text is NULL/UNDEF")
            return;
        }

        val departuretime = (TrainDeparture_Time.state as DateTimeType).getZonedDateTime(ZoneId.systemDefault())
        if (TrainStatus_Text.state == "ON_TIME") {
            //val trainmessage = "Zug " + departuretime.getHour() + ":" + departuretime.getMinute() + " on time."
            val trainmessage = String.format("Zug %02d:%02d on time.", departuretime.getHour(), departuretime.getMinute())

            val color = "#00FF00"
            Ulanzi_Train.sendCommand("{\"text\":\"" + trainmessage  + "\",\"color\":\"" + color + "\",\"icon\":\"12738\"}")
            logInfo("ulanzi_train", "Trainmessage: " + trainmessage)
        }
        else {
            // NULL guard for delay
            if (TrainDelay_Minutes.state == NULL || TrainDelay_Minutes.state == UNDEF) {
                logWarn("ulanzi_train", "TrainDelay_Minutes is NULL/UNDEF")
                return;
            }

            val trainmessage = String.format("Zug %02d:%02d is %d min late.", departuretime.getHour(), departuretime.getMinute(), TrainDelay_Minutes.state())
            //val trainmessage = "Zug " + departuretime.getHour() + ":" + departuretime.getMinute() + " is " + TrainDelay_Minutes.state() + " min late."

            val color = "#FF0000"
            Ulanzi_Train.sendCommand("{\"text\":\"" + trainmessage  + "\",\"color\":\"" + color + "\",\"icon\":\"12738\"}")
            logInfo("ulanzi_train", "Trainmessage: " + trainmessage)
        }
    }
end

// Reset Ulanzi
rule "ulanzi_reset"
when
    Time cron "1 3 1 ? * * *"
then
    val status = Ulanzi_Status.state
    logInfo("ulanzi_status", "Ulanzi status: " + status)
    if (Ulanzi_Status.state == NULL) {
        logInfo("ulanzi_status", "Resetting Ulanzi")
        logInfo("ulanzi_status", "Ulanzi Reboot")
        Ulanzi_Reboot.sendCommand("")
        logInfo("ulanzi_status", "Ulanzi reset settings")
        Ulanzi_Settings.sendCommand("{ \"ATIME\": \"8\", \"ABRI\" : true, \"TEMP\": false, \"HUM\": false }")
    }
end
