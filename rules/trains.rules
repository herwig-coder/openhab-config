// ============================================================================
// RULE 9: Smart Departure Reminder
// ============================================================================

rule "Departure Reminder"
when
    Time cron "0 * * ? * *"  // Run every hour
then
    val status = TrainStatus_Text.state.toString
    val departureStr = TrainDeparture_Time.state.toString

    if (!status.equals("NOT_FOUND") && !departureStr.equals("NULL")) {
        try {
            // Parse departure time
            val formatter = DateTimeFormatter.ISO_DATE_TIME
            val departureTime = ZonedDateTime.parse(departureStr, formatter)
            val now = ZonedDateTime.now()

            // Calculate time until departure
            val minutesUntil = java.time.Duration.between(now, departureTime).toMinutes()

            // Send reminder 45 minutes before departure
            if (minutesUntil >= 40 && minutesUntil <= 45) {
                var message = "Reminder: Your train departs in 45 minutes"

                if (TrainDelay_Minutes.state !== NULL && TrainDelay_Minutes.state !== UNDEF) {
                    val delay = TrainDelay_Minutes.state as Number
                    if (delay !== null && delay.intValue > 0) {
                        message = message + String.format(" (delayed by %d min)", delay.intValue)
                    }
                }

                logInfo("TrainTracker", message)
                // sendNotification(NOTIFICATION_EMAIL, message)
            }
        } catch (Exception e) {
            logDebug("TrainTracker", "Could not parse departure time: " + e.getMessage())
        }
    }
end


// ============================================================================
// RULE 10: Error Handling - Script Failures
// ============================================================================

rule "Train Tracker Error Detection"
when
    Item TrainStatus_Text changed to "ERROR" or
    Item TrainStatus_Text changed to "NOT_FOUND"
then
    val status = TrainStatus_Text.state.toString

    if (status.equals("ERROR")) {
        logError("TrainTracker", "Train tracker script reported an error. Check logs.")
    } else if (status.equals("NOT_FOUND")) {
        logWarn("TrainTracker", "No matching train found. Check configuration or schedule.")
    }
end
