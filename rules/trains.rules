/**
 * OpenHAB Rules for Train Tracker
 *
 * This file contains automation rules for the train delay tracker.
 * Place this file in: conf/rules/trains.rules
 */

import java.time.ZonedDateTime
import java.time.format.DateTimeFormatter

// ============================================================================
// CONFIGURATION - UPDATE THESE PATHS FOR YOUR SYSTEM
// ============================================================================

// Scripts live inside the git repo at /etc/openhab/Scripts/train-tracker/
val String SCRIPT_PATH = "/etc/openhab/Scripts/train-tracker/venv/bin/python"
val String TRACKER_SCRIPT = "/etc/openhab/Scripts/train-tracker/train_tracker.py"

val String NOTIFICATION_EMAIL = "herwig.kaltenhauser@gmx.at"  // For sendNotification

// Configuration values - UPDATE THESE FOR YOUR ROUTE
val String ORIGIN_STATION = "Strasshof/Nordbahn"
val String DESTINATION_STATION = "Wien Praterstern"
val String SCHEDULED_TIME = "07:55"
val String MAX_CHANGES = "0"  // Maximum train changes (0=direct only, 1=one transfer, etc.)


// ============================================================================
// RULE 0: Next two trains — runs every 15 min, 8:00–9:45 AM Mon–Fri
// ============================================================================

rule "Next Trains Update"
when
    Time cron "0 0/15 8-20 ? * MON-FRI"
then
    logInfo("NextTrains", "Fetching next 2 trains from now...")

    val results = executeCommandLine(
        Duration.ofSeconds(30),
        SCRIPT_PATH,
        TRACKER_SCRIPT,
        "--origin", ORIGIN_STATION,
        "--destination", DESTINATION_STATION,
        "--max-changes", MAX_CHANGES,
        "--count", "2"
    )

    if (results === null || results.equals("")) {
        logError("NextTrains", "Script returned no output")
        return;
    }

    logDebug("NextTrains", "JSON output: " + results)

    try {
        // Train 1
        val t1Status  = transform("JSONPATH", "$.trains[0].status",        results)
        val t1Dep     = transform("JSONPATH", "$.trains[0].departure_time", results)
        val t1Arr     = transform("JSONPATH", "$.trains[0].arrival_time",   results)
        val t1Type    = transform("JSONPATH", "$.trains[0].train_type",     results)
        val t1Name    = transform("JSONPATH", "$.trains[0].train_name",     results)
        val t1Delay   = transform("JSONPATH", "$.trains[0].delay_minutes",  results)

        if (t1Status !== null) Train_Next1_Status.postUpdate(t1Status)
        if (t1Type   !== null && !t1Type.equals("null"))   Train_Next1_Type.postUpdate(t1Type)
        if (t1Name   !== null && !t1Name.equals("null"))   Train_Next1_Name.postUpdate(t1Name)
        if (t1Dep    !== null && !t1Dep.equals("null"))    Train_Next1_Departure.postUpdate(t1Dep)
        if (t1Arr    !== null && !t1Arr.equals("null"))    Train_Next1_Arrival.postUpdate(t1Arr)
        if (t1Delay  !== null) Train_Next1_Delay.postUpdate(Integer::parseInt(t1Delay))

        // Train 2
        val t2Status  = transform("JSONPATH", "$.trains[1].status",        results)
        val t2Dep     = transform("JSONPATH", "$.trains[1].departure_time", results)
        val t2Arr     = transform("JSONPATH", "$.trains[1].arrival_time",   results)
        val t2Type    = transform("JSONPATH", "$.trains[1].train_type",     results)
        val t2Name    = transform("JSONPATH", "$.trains[1].train_name",     results)
        val t2Delay   = transform("JSONPATH", "$.trains[1].delay_minutes",  results)

        if (t2Status !== null) Train_Next2_Status.postUpdate(t2Status)
        if (t2Type   !== null && !t2Type.equals("null"))   Train_Next2_Type.postUpdate(t2Type)
        if (t2Name   !== null && !t2Name.equals("null"))   Train_Next2_Name.postUpdate(t2Name)
        if (t2Dep    !== null && !t2Dep.equals("null"))    Train_Next2_Departure.postUpdate(t2Dep)
        if (t2Arr    !== null && !t2Arr.equals("null"))    Train_Next2_Arrival.postUpdate(t2Arr)
        if (t2Delay  !== null) Train_Next2_Delay.postUpdate(Integer::parseInt(t2Delay))

        logInfo("NextTrains", "Train1: {} {} dep={} arr={} delay={}min",
            t1Type, t1Name, t1Dep, t1Arr, t1Delay)
        logInfo("NextTrains", "Train2: {} {} dep={} arr={} delay={}min",
            t2Type, t2Name, t2Dep, t2Arr, t2Delay)

    } catch (Exception e) {
        logError("NextTrains", "Error parsing next trains JSON: " + e.getMessage())
    }
end


// ============================================================================
// RULE 1: Run Train Tracker Periodically
// ============================================================================

rule "Update Train Status"
when
    // Run every 15 minutes between 6 AM and 10 AM on weekdays
    Time cron "0 */15 6-9 ? * MON-FRI"
then
    logInfo("TrainTracker", "Running train status check...")

    // Execute the Python script (returns JSON)
    val results = executeCommandLine(
        Duration.ofSeconds(30),  // 30 second timeout
        SCRIPT_PATH,
        TRACKER_SCRIPT,
        "--origin", ORIGIN_STATION,
        "--destination", DESTINATION_STATION,
        "--time", SCHEDULED_TIME,
        "--max-changes", MAX_CHANGES
    )

    // Parse JSON output and update items
    if (results !== null && !results.equals("")) {
        try {
            logDebug("TrainTracker", "JSON output: " + results)

            // Parse JSON using JSONPATH transformation
            val status = transform("JSONPATH", "$.status", results)
            val delayStr = transform("JSONPATH", "$.delay_minutes", results)
            val departureTime = transform("JSONPATH", "$.departure_time", results)
            val arrivalTime = transform("JSONPATH", "$.arrival_time", results)
            val trainType = transform("JSONPATH", "$.train_type", results)
            val trainName = transform("JSONPATH", "$.train_name", results)

            // Update OpenHAB items directly
            if (status !== null) {
                TrainStatus_Text.postUpdate(status)
                logInfo("TrainTracker", "Status: " + status)
            }

            if (delayStr !== null) {
                val delay = Integer::parseInt(delayStr)
                TrainDelay_Minutes.postUpdate(delay)
                logInfo("TrainTracker", "Delay: " + delay + " min")
            }

            if (trainType !== null && !trainType.equals("null")) {
                TrainType.postUpdate(trainType)
                logInfo("TrainTracker", "Train type: " + trainType)
            }

            if (trainName !== null && !trainName.equals("null")) {
                TrainName.postUpdate(trainName)
                logInfo("TrainTracker", "Train name: " + trainName)
            }

            if (departureTime !== null && !departureTime.equals("null")) {
                TrainDeparture_Time.postUpdate(departureTime)
                logInfo("TrainTracker", "Departure: " + departureTime)
            }

            if (arrivalTime !== null && !arrivalTime.equals("null")) {
                TrainArrival_Time.postUpdate(arrivalTime)
                logInfo("TrainTracker", "Arrival: " + arrivalTime)
            }
        } catch (Exception e) {
            logError("TrainTracker", "Error parsing train data: " + e.getMessage())
            TrainStatus_Text.postUpdate("ERROR")
        }
    } else {
        logError("TrainTracker", "Script execution failed or timed out")
        TrainStatus_Text.postUpdate("ERROR")
    }
end


// ============================================================================
// RULE 2: Alert on Train Delays
// ============================================================================

rule "Train Delay Alert"
when
    Item TrainStatus_Text changed to "DELAYED"
then
    // Check for NULL state before casting
    if (TrainDelay_Minutes.state === NULL || TrainDelay_Minutes.state === UNDEF) {
        logWarn("TrainTracker", "Delay value not available yet")
        return
    }

    val delay = TrainDelay_Minutes.state as Number

    if (delay !== null && delay.intValue > 5) {
        val message = String.format(
            "Your train is delayed by %d minutes! New departure time: %s",
            delay.intValue,
            TrainDeparture_Time.state.toString
        )

        logWarn("TrainTracker", message)

        // Send notification (requires notification action configured in OpenHAB)
        // sendNotification(NOTIFICATION_EMAIL, message)

        // Or send to phone via Telegram/Pushover if configured
        // sendTelegram("bot1", message)
    }
end


// ============================================================================
// RULE 3: Alert on Train Cancellation
// ============================================================================

rule "Train Cancelled Alert"
when
    Item TrainStatus_Text changed to "CANCELLED"
then
    val message = "⚠️ Your train has been CANCELLED! Check for alternatives."

    logError("TrainTracker", message)

    // Send urgent notification
    // sendNotification(NOTIFICATION_EMAIL, message)

    // Flash a light or send to smart display
    // MyWarningLight.sendCommand(ON)
end


// ============================================================================
// RULE 4: Train Status Changed - General Logger
// ============================================================================

rule "Train Status Changed"
when
    Item TrainStatus_Text changed
then
    val status = TrainStatus_Text.state.toString
    var message = "Train status: " + status

    // Safely check delay (may be NULL)
    if (TrainDelay_Minutes.state !== NULL && TrainDelay_Minutes.state !== UNDEF) {
        val delay = TrainDelay_Minutes.state as Number
        if (delay !== null && delay.intValue > 0) {
            message = message + String.format(" (Delay: %d min)", delay.intValue)
        }
    }

    // Safely check departure time (may be NULL)
    if (TrainDeparture_Time.state !== NULL && TrainDeparture_Time.state !== UNDEF) {
        val departure = TrainDeparture_Time.state.toString
        if (departure !== null && !departure.equals("NULL")) {
            message = message + " | Departure: " + departure
        }
    }

    logInfo("TrainTracker", message)
end


// ============================================================================
// RULE 5: Morning Train Check - Run Before Commute
// ============================================================================

rule "Morning Train Check"
when
    // Run at 6:30 AM on weekdays (adjust to your schedule)
    Time cron "0 30 6 ? * MON-FRI"
then
    logInfo("TrainTracker", "Running morning train check...")

    // Execute the script (returns JSON)
    val results = executeCommandLine(
        Duration.ofSeconds(30),
        SCRIPT_PATH,
        TRACKER_SCRIPT,
        "--origin", ORIGIN_STATION,
        "--destination", DESTINATION_STATION,
        "--time", SCHEDULED_TIME,
        "--max-changes", MAX_CHANGES
    )

    // Parse JSON and update items
    var String status = "UNKNOWN"
    var Number delay = null

    if (results !== null && !results.equals("")) {
        try {
            val statusStr = transform("JSONPATH", "$.status", results)
            val delayStr = transform("JSONPATH", "$.delay_minutes", results)
            val departureTime = transform("JSONPATH", "$.departure_time", results)
            val arrivalTime = transform("JSONPATH", "$.arrival_time", results)
            val trainType = transform("JSONPATH", "$.train_type", results)
            val trainName = transform("JSONPATH", "$.train_name", results)

            // Update items
            if (statusStr !== null) {
                TrainStatus_Text.postUpdate(statusStr)
                status = statusStr
            }

            if (delayStr !== null) {
                delay = Integer::parseInt(delayStr)
                TrainDelay_Minutes.postUpdate(delay)
            }

            if (trainType !== null && !trainType.equals("null")) {
                TrainType.postUpdate(trainType)
            }

            if (trainName !== null && !trainName.equals("null")) {
                TrainName.postUpdate(trainName)
            }

            if (departureTime !== null && !departureTime.equals("null")) {
                TrainDeparture_Time.postUpdate(departureTime)
            }

            if (arrivalTime !== null && !arrivalTime.equals("null")) {
                TrainArrival_Time.postUpdate(arrivalTime)
            }
        } catch (Exception e) {
            logError("TrainTracker", "Error parsing train data: " + e.getMessage())
            TrainStatus_Text.postUpdate("ERROR")
            status = "ERROR"
        }
    } else {
        logError("TrainTracker", "Script execution failed")
        TrainStatus_Text.postUpdate("ERROR")
        status = "ERROR"
    }

    // Send morning summary based on status
    if (status.equals("DELAYED")) {
        if (delay !== null && delay.intValue > 10) {
            val message = String.format(
                "Good morning! Your train is delayed by %d minutes. Consider leaving earlier.",
                delay.intValue
            )
            // sendNotification(NOTIFICATION_EMAIL, message)
            logWarn("TrainTracker", message)
        }
    } else if (status.equals("ON_TIME")) {
        logInfo("TrainTracker", "Good morning! Your train is on time.")
    }
end


// ============================================================================
// RULE 6: High Delay Warning
// ============================================================================

rule "High Delay Warning"
when
    Item TrainDelay_Minutes changed
then
    // Check for NULL state
    if (TrainDelay_Minutes.state === NULL || TrainDelay_Minutes.state === UNDEF) {
        return
    }

    val delay = TrainDelay_Minutes.state as Number

    if (delay !== null) {
        if (delay.intValue >= 30) {
            logError("TrainTracker", String.format("⚠️ MAJOR DELAY: %d minutes!", delay.intValue))
            // Consider alternative transportation
            // sendNotification(NOTIFICATION_EMAIL, "Major train delay! Consider taxi/car.")
        } else if (delay.intValue >= 15) {
            logWarn("TrainTracker", String.format("Significant delay: %d minutes", delay.intValue))
        }
    }
end


// ============================================================================
// RULE 7: Weekend/Holiday - Skip Tracking
// ============================================================================

rule "Disable Weekend Tracking"
when
    System started
then
    logInfo("TrainTracker", "Train tracker rules loaded")
    logInfo("TrainTracker", "Scheduled checks: Every 15 min, 6-10 AM, Mon-Fri")
    logInfo("TrainTracker", "Morning check: 6:30 AM, Mon-Fri")
end


