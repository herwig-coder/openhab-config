////////////////////////////////////////////////////////
/// Airing thresholds (year-round, self-seasoning)
////////////////////////////////////////////////////////
// Decision is based on the DIFFERENCE between indoor and outdoor dewpoint
// (delta = indoor - outdoor), NOT an absolute indoor dewpoint. Opening a
// window can only remove moisture down to the outdoor dewpoint, so a fixed
// 18 °C target is unreachable in summer (outdoor dewpoint ~16-20 °C) and the
// alert never clears. The delta auto-adjusts: winter (outdoor ~2 °C) behaves
// like before, summer stays sane.
val Number AIR_DELTA_ON  = 3.0   // °C indoor over outdoor -> removable excess moisture, start airing
val Number AIR_DELTA_OFF = 1.0   // °C indoor over outdoor -> practical floor reached, stop airing
val Number AIR_MOLD_FLOOR = 16.0 // °C indoor dewpoint below which mold risk is negligible -> never nag

// Heat guard (bedrooms only; bathroom is exempt so it still vents shower moisture).
// Don't tell to air when the incoming air would warm the room or it's simply hot outside.
val Number AIR_HEAT_MARGIN = 2.0  // °C outdoor may exceed indoor and still be worth airing
val Number AIR_MAX_OUTDOOR = 25.0 // °C absolute outdoor cap: above this, never air bedrooms

////////////////////////////////////////////////////////
/// Bathroom Dewpoint Alert
////////////////////////////////////////////////////////
rule "dewpointBadAlert"
when
    Item Bathroom_DewPoint changed
then
    logInfo("Bad_Dewpoint_Alert", "Trigger: Bathroom_Dewpoint changed")

    // NULL guards - CRITICAL
    if (Bathroom_DewPoint.state == NULL || Bathroom_DewPoint.state == UNDEF) {
        logWarn("Bad_Dewpoint_Alert", "Bathroom_DewPoint is NULL/UNDEF, skipping")
        return;
    }
    if (OneCallAPIweatherandforecast_Current_Dewpoint.state == NULL || OneCallAPIweatherandforecast_Current_Dewpoint.state == UNDEF) {
        logWarn("Bad_Dewpoint_Alert", "OneCallAPIweatherandforecast_Current_Dewpoint is NULL/UNDEF, skipping")
        return;
    }

    if (Bathroom_DewPoint.state instanceof QuantityType ) {
        // Indoor vs. outdoor dewpoint: airing only removes moisture when indoor > outdoor.
        val temp        = (Bathroom_DewPoint.state as QuantityType<Number>).toUnit("°C").doubleValue
        val outdewpoint = (OneCallAPIweatherandforecast_Current_Dewpoint.state as QuantityType<Number>).toUnit("°C").doubleValue
        val delta       = temp - outdewpoint
        logInfo("Bad_Dewpoint_Alert", "Indoor dewpoint: {} °C, Outdoor: {} °C, Delta: {} °C", temp, outdewpoint, delta)

        // Removable excess moisture present AND mold-relevant -> air.
        if ((delta >= AIR_DELTA_ON.doubleValue) && (temp > AIR_MOLD_FLOOR.doubleValue)) {
            if (Bathroom_DewPoint_Alert.state != ON){
                val telegramAction = getActions("telegram","telegram:telegramBot:Telegram_Bot")
                val message = "ALERT! Bathroom: Time to air. Dewpoint at: " + String.format("%.1f",temp) + " °C (outside " + String.format("%.1f",outdewpoint) + " °C)"
                telegramAction.sendTelegram(message)
                logInfo("Bad_Dewpoint_Alert", "Alert sent: {}", message)
                Bathroom_DewPoint_Alert.postUpdate(ON)
            }
            else{
                logInfo("Bad_Dewpoint_Alert", "Already alerting, not re-sending")
            }
        }
        // Aired to practical floor, or moisture harmless anyway -> stop.
        else if ((delta <= AIR_DELTA_OFF.doubleValue) || (temp <= AIR_MOLD_FLOOR.doubleValue)) {
            if (Bathroom_DewPoint_Alert.state == ON){
                val telegramAction = getActions("telegram","telegram:telegramBot:Telegram_Bot")
                val message = "Bathroom: aired enough. Dewpoint at: " + String.format("%.1f",temp) + " °C (outside " + String.format("%.1f",outdewpoint) + " °C)"
                telegramAction.sendTelegram(message)
                logInfo("Bad_Dewpoint_Alert", "Alert off sent: {}", message)
                Bathroom_DewPoint_Alert.postUpdate(OFF)
            }
        }
        // else: delta within hysteresis band (AIR_DELTA_OFF..AIR_DELTA_ON) -> keep current state.
    }
    else {
        logWarn("Bad_Dewpoint_Alert", "Invalid input: Bathroom_DewPoint state is not a QuantityType")
    }
end


////////////////////////////////////////////////////////
/// Paretns Beddroom Dewpoint Alert
////////////////////////////////////////////////////////
rule "dewpointBedroomAlert"
when
    Item ParentsBedroom_DewPoint changed
then
    logInfo("Partentsbedroom_Dewpoint_Alert", "Trigger: Parents Bedroom Dewpoint changed")

    // NULL guards - CRITICAL
    if (ParentsBedroom_DewPoint.state == NULL || ParentsBedroom_DewPoint.state == UNDEF) {
        logWarn("Partentsbedroom_Dewpoint_Alert", "ParentsBedroom_DewPoint is NULL/UNDEF, skipping")
        return;
    }
    if (OneCallAPIweatherandforecast_Current_Dewpoint.state == NULL || OneCallAPIweatherandforecast_Current_Dewpoint.state == UNDEF) {
        logWarn("Partentsbedroom_Dewpoint_Alert", "OneCallAPIweatherandforecast_Current_Dewpoint is NULL/UNDEF, skipping")
        return;
    }

    if (ParentsBedroom_DewPoint.state instanceof QuantityType &&
        ParentsBedroom_Temperature.state instanceof QuantityType &&
        OneCallAPIweatherandforecast_Current_Temperature.state instanceof QuantityType) {
        // Indoor vs. outdoor dewpoint: airing only removes moisture when indoor > outdoor.
        val temp        = (ParentsBedroom_DewPoint.state as QuantityType<Number>).toUnit("°C").doubleValue
        val outdewpoint = (OneCallAPIweatherandforecast_Current_Dewpoint.state as QuantityType<Number>).toUnit("°C").doubleValue
        val delta       = temp - outdewpoint
        // Heat guard: don't air if incoming air would warm the room, or it's simply hot outside.
        val intemp  = (ParentsBedroom_Temperature.state as QuantityType<Number>).toUnit("°C").doubleValue
        val outtemp = (OneCallAPIweatherandforecast_Current_Temperature.state as QuantityType<Number>).toUnit("°C").doubleValue
        val canCool = (outtemp <= intemp + AIR_HEAT_MARGIN.doubleValue) && (outtemp <= AIR_MAX_OUTDOOR.doubleValue)
        logInfo("Partentsbedroom_Dewpoint_Alert", "Dewpoint in/out: {}/{} °C (delta {}), Temp in/out: {}/{} °C, canCool: {}", temp, outdewpoint, delta, intemp, outtemp, canCool)

        // Removable excess moisture, mold-relevant, AND airing won't overheat the room -> air.
        if ((delta >= AIR_DELTA_ON.doubleValue) && (temp > AIR_MOLD_FLOOR.doubleValue) && canCool) {
            if (ParentsBedroom_DewPoint_Alert.state != ON){
                val telegramAction = getActions("telegram","telegram:telegramBot:Telegram_Bot")
                val message = "ALERT! Parents Bedroom: Time to air. Dewpoint at: " + String.format("%.1f",temp) + " °C (outside " + String.format("%.1f",outdewpoint) + " °C)"
                telegramAction.sendTelegram(message)
                logInfo("Partentsbedroom_Dewpoint_Alert", "Alert sent: {}", message)
                ParentsBedroom_DewPoint_Alert.postUpdate(ON)
            }
            else{
                logInfo("Partentsbedroom_Dewpoint_Alert", "Already alerting, not re-sending")
            }
        }
        // Aired to floor, moisture harmless, or too warm/hot outside to air -> stop.
        else if ((delta <= AIR_DELTA_OFF.doubleValue) || (temp <= AIR_MOLD_FLOOR.doubleValue) || !canCool) {
            if (ParentsBedroom_DewPoint_Alert.state == ON){
                val telegramAction = getActions("telegram","telegram:telegramBot:Telegram_Bot")
                val message = if (!canCool)
                        "Parents Bedroom: too warm outside to air (out " + String.format("%.1f",outtemp) + " °C / in " + String.format("%.1f",intemp) + " °C). Will alert when it cools."
                    else
                        "Parents Bedroom: aired enough. Dewpoint at: " + String.format("%.1f",temp) + " °C (outside " + String.format("%.1f",outdewpoint) + " °C)"
                telegramAction.sendTelegram(message)
                logInfo("Partentsbedroom_Dewpoint_Alert", "Alert off sent: {}", message)
                ParentsBedroom_DewPoint_Alert.postUpdate(OFF)
            }
        }
        // else: delta within hysteresis band -> keep current state.
    }
    else {
        logWarn("Partentsbedroom_Dewpoint_Alert", "Invalid input: a required Item state is not a QuantityType")
    }
end

////////////////////////////////////////////////////////
/// Tommy Beddroom Dewpoint Alert
////////////////////////////////////////////////////////
rule "dewpointBedroomTommyAlert"
when
    Item ChildrenBedroom_DewPoint changed
then
    logInfo("BedroomTommy_Dewpoint_Alert", "Trigger: Tommy Bedroom Dewpoint changed")

    // NULL guards - CRITICAL
    if (ChildrenBedroom_DewPoint.state == NULL || ChildrenBedroom_DewPoint.state == UNDEF) {
        logWarn("BedroomTommy_Dewpoint_Alert", "ChildrenBedroom_DewPoint is NULL/UNDEF, skipping")
        return;
    }
    if (OneCallAPIweatherandforecast_Current_Dewpoint.state == NULL || OneCallAPIweatherandforecast_Current_Dewpoint.state == UNDEF) {
        logWarn("BedroomTommy_Dewpoint_Alert", "OneCallAPIweatherandforecast_Current_Dewpoint is NULL/UNDEF, skipping")
        return;
    }

    if (ChildrenBedroom_DewPoint.state instanceof QuantityType &&
        ChildrenBedroom_Temperature.state instanceof QuantityType &&
        OneCallAPIweatherandforecast_Current_Temperature.state instanceof QuantityType) {
        // Indoor vs. outdoor dewpoint: airing only removes moisture when indoor > outdoor.
        val temp        = (ChildrenBedroom_DewPoint.state as QuantityType<Number>).toUnit("°C").doubleValue
        val outdewpoint = (OneCallAPIweatherandforecast_Current_Dewpoint.state as QuantityType<Number>).toUnit("°C").doubleValue
        val delta       = temp - outdewpoint
        // Heat guard: don't air if incoming air would warm the room, or it's simply hot outside.
        val intemp  = (ChildrenBedroom_Temperature.state as QuantityType<Number>).toUnit("°C").doubleValue
        val outtemp = (OneCallAPIweatherandforecast_Current_Temperature.state as QuantityType<Number>).toUnit("°C").doubleValue
        val canCool = (outtemp <= intemp + AIR_HEAT_MARGIN.doubleValue) && (outtemp <= AIR_MAX_OUTDOOR.doubleValue)
        logInfo("BedroomTommy_Dewpoint_Alert", "Dewpoint in/out: {}/{} °C (delta {}), Temp in/out: {}/{} °C, canCool: {}", temp, outdewpoint, delta, intemp, outtemp, canCool)

        // Removable excess moisture, mold-relevant, AND airing won't overheat the room -> air.
        if ((delta >= AIR_DELTA_ON.doubleValue) && (temp > AIR_MOLD_FLOOR.doubleValue) && canCool) {
            if (ChildrenBedroom_DewPoint_Alert.state != ON){
                val telegramAction = getActions("telegram","telegram:telegramBot:Telegram_Bot")
                val message = "ALERT! Tommy Bedroom: Time to air. Dewpoint at: " + String.format("%.1f",temp) + " °C (outside " + String.format("%.1f",outdewpoint) + " °C)"
                telegramAction.sendTelegram(message)
                logInfo("BedroomTommy_Dewpoint_Alert", "Alert sent: {}", message)
                ChildrenBedroom_DewPoint_Alert.postUpdate(ON)
            }
            else{
                logInfo("BedroomTommy_Dewpoint_Alert", "Already alerting, not re-sending")
            }
        }
        // Aired to floor, moisture harmless, or too warm/hot outside to air -> stop.
        else if ((delta <= AIR_DELTA_OFF.doubleValue) || (temp <= AIR_MOLD_FLOOR.doubleValue) || !canCool) {
            if (ChildrenBedroom_DewPoint_Alert.state == ON){
                val telegramAction = getActions("telegram","telegram:telegramBot:Telegram_Bot")
                val message = if (!canCool)
                        "Tommy Bedroom: too warm outside to air (out " + String.format("%.1f",outtemp) + " °C / in " + String.format("%.1f",intemp) + " °C). Will alert when it cools."
                    else
                        "Tommy Bedroom: aired enough. Dewpoint at: " + String.format("%.1f",temp) + " °C (outside " + String.format("%.1f",outdewpoint) + " °C)"
                telegramAction.sendTelegram(message)
                logInfo("BedroomTommy_Dewpoint_Alert", "Alert off sent: {}", message)
                ChildrenBedroom_DewPoint_Alert.postUpdate(OFF)
            }
        }
        // else: delta within hysteresis band -> keep current state.
    }
    else {
        logWarn("BedroomTommy_Dewpoint_Alert", "Invalid input: a required Item state is not a QuantityType")
    }
end
