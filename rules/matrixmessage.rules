
rule "UpdateMatrixMessage"
when
    Item Garbage_Collection_Message changed 

then
    logInfo("UpdateMatrixMessage", "Trigger: New Muellmessage")
    if (Garbage_Collection_Message.state.toString=="NULL")
    {
        logInfo("UpdateMatrixMessage", "Muellmessage empty - clear display")
        Corridor_Message.sendCommand("")
    }
    else{
        logInfo("UpdateMatrixMessage", "Muellmessage {}", Garbage_Collection_Message.state)
        Corridor_Message.sendCommand(Garbage_Collection_Message.state.toString.toUpperCase)
    }
    

end
