// ────────────────────────────────────────────────────────────────────────────
// Poolhaus-Ulanzi (Awtrix Light, MQTT-Prefix "ulanzipool").
// Baseline: Kitchen-Ulanzi (rules/ulanzimessages.rules).
// Zeigt: Zeit mit Sekunden (kein Datum), Aussentemp + Luftfeuchte von der
// Wetterstation (nicht dem internen Ulanzi-Sensor). Wassertemp/PH/ORP folgen aus
// dem Pool-Modbus (Phase 2/3) — unten als auskommentierte Stubs vorbereitet.
//
// Custom-App-Payload: {"text":"...","color":"#RRGGBB","icon":"<LaMetric-ID>"}
// Icon-IDs unten sind Platzhalter — bei Bedarf an eigene LaMetric-Icons anpassen.
// ────────────────────────────────────────────────────────────────────────────

// Awtrix-Settings: Zeit m. Sekunden, kein Datum, keine Batterie, keine internen
// Temp/Feuchte-Apps (die Werte kommen als Custom-Apps von der Wetterstation).
// Awtrix-Settings zentral (Zeit m. Sekunden, kein Datum/Batterie, interne Temp/Feuchte aus).
// Wird bei openHAB-Start UND im täglichen Reset-Check gesendet.
// Hinweis: In Awtrix Light heissen die App-Schalter fuer Zeit/Datum TIM/DAT
// (nur HUM/TEMP/BAT sind ausgeschrieben). TIME/DATE werden ignoriert.
val String ULANZIPOOL_SETTINGS = "{\"ATIME\":\"8\",\"ABRI\":true,\"TIM\":true,\"DAT\":false,\"TEMP\":false,\"HUM\":false,\"BAT\":false,\"TFORMAT\":\"%H:%M:%S\"}"

rule "ulanzipool_settings"
when
    System started
then
    logInfo("ulanzipool", "System started -> Awtrix-Settings senden")
    UlanziPool_Settings.sendCommand(ULANZIPOOL_SETTINGS)
end

// Täglicher Reset-/Recovery-Check (wie bei der Küchen-Ulanzi): reagiert die Uhr
// nicht mehr (Status NULL), einmal rebooten und die Settings neu senden.
rule "ulanzipool_reset"
when
    Time cron "1 5 1 ? * * *"
then
    logInfo("ulanzipool", "Reset-Check, Status: {}", UlanziPool_Status.state)
    if (UlanziPool_Status.state == NULL) {
        logInfo("ulanzipool", "Poolhaus-Ulanzi reagiert nicht -> Reboot + Settings neu")
        UlanziPool_Reboot.sendCommand("")
        UlanziPool_Settings.sendCommand(ULANZIPOOL_SETTINGS)
    }
end

rule "ulanzipool_outtemp"
when
    Item Weatherstation_Temperature_1 changed
then
    if (Weatherstation_Temperature_1.state == NULL || Weatherstation_Temperature_1.state == UNDEF) {
        return;
    }
    val t = (Weatherstation_Temperature_1.state as QuantityType<Number>).toUnit("°C").doubleValue
    val msg = "{\"text\":\"" + String.format("%.1f",t) + "°C\",\"color\":\"#FFA500\",\"icon\":\"2355\"}"
    logInfo("ulanzipool", "Aussentemp -> Ulanzi: {}", msg)
    UlanziPool_OutTemp.sendCommand(msg)
end

rule "ulanzipool_outhum"
when
    Item Weatherstation_Humidity_1 changed
then
    if (Weatherstation_Humidity_1.state == NULL || Weatherstation_Humidity_1.state == UNDEF) {
        return;
    }
    val h = (Weatherstation_Humidity_1.state as QuantityType<Number>).doubleValue
    val msg = "{\"text\":\"" + String.format("%.0f",h) + "%\",\"color\":\"#00BFFF\",\"icon\":\"53330\"}"
    logInfo("ulanzipool", "Feuchte -> Ulanzi: {}", msg)
    UlanziPool_OutHum.sendCommand(msg)
end

