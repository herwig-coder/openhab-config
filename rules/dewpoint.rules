import java.lang.Math

// Define a reusable closure for dewpoint calculation
val calculateDewpoint = [ Number temp, Number humidity |
    val a = 17.27
    val b = 237.7
    val alpha = (a * temp) / (b + temp) + Math.log(humidity.doubleValue / 100.0)
    val dewpoint = Math.round(((b * alpha) / (a - alpha))*100.0)/100.0  //rounding to 2 digits
    dewpoint
]

rule "dewpointBad"
when
    Item Bathroom_Temperature changed or
    Item Bathroom_Humidity changed
then
    logInfo("Bad_Dewpoint", "Trigger: Bathroom_Temperature or Bathroom_Humidity changed")

    if (Bathroom_Temperature.state instanceof QuantityType && Bathroom_Humidity.state instanceof QuantityType) {
        // Extract temperature and humidity values
        val temp = (Bathroom_Temperature.state as QuantityType<Number>).toUnit("°C").doubleValue
        val humidity = (Bathroom_Humidity.state as QuantityType<Number>).toUnit("%").doubleValue

        // Log the input values
        logInfo("Bathroom_Dewpoint", "Input values - Temperature: {} °C, Humidity: {} %", temp, humidity)

        // Use the closure for calculation
        val dewpoint = calculateDewpoint.apply(temp, humidity)

        // Log the calculated dewpoint
        logInfo("Bathroom_Dewpoint", "Calculated Dewpoint: {} °C", dewpoint)

        // Update the Bathroom_Dewpoint item
        Bathroom_Last_DewPoint.postUpdate(Bathroom_DewPoint.state)
        Bathroom_DewPoint.postUpdate(dewpoint)
    } 
    else {
        logWarn("Bathroom_DewPoint", "Invalid input: Bad_Temperature or Bad_Humidity state is not a QuantityType")
    }
end

