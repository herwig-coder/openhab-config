// Aqara Wireless Switches — Aktions-Mapping auf Raffstores / Lichter.
// Items in items/aqara_switches.items, Channels in things/MQTT_AquaraSwitches.things.

import org.openhab.core.library.types.DecimalType
import org.openhab.core.library.types.StopMoveType
import org.openhab.core.library.types.UpDownType

// --- Büro Zorina ----------------------------------------------------------
// Aqara 2-Wippen-Switch steuert OfficeBig_Rollershutter + Tilt.
// Mapping (kurz = kleiner Schritt, lang = große Aktion — matcht Shelly-Stil
// aus shelly.rules / Esszimmer):
//   single_left  → Tilt −10 % (mehr offen)
//   single_right → Tilt +10 % (mehr zu)
//   hold_left    → UP (oder STOP wenn gerade in Bewegung — Toggle-Muster)
//   hold_right   → DOWN (oder STOP wenn gerade in Bewegung)
//
// State-Tracking über das virtuelle Switch-Item OfficeBig_Rollershutter_Moving.
// Vorteil ggü. file-level var: in OH5-UI sichtbar zum Debuggen, übersteht
// Rule-Reloads. Soft-Timer setzt Moving nach typischer Raffstore-Laufzeit
// (40 s) automatisch zurück damit ein erneuter Klick wieder eine Bewegung
// startet falls der Stop-Press verpasst wurde.

var Timer OfficeBig_Rollershutter_MovingTimer = null

rule "Aqara Office Zorina — Action Mapping"
when
    Item OfficeBig_AqaraSwitch_Action received update
then
    val action = OfficeBig_AqaraSwitch_Action.state.toString
    val movingState = OfficeBig_Rollershutter_Moving.state
    logInfo("AqaraZorina", "Action: " + action + "  (Moving=" + movingState + ")")

    switch (action) {
        case "single_left": {
            val currentTilt = (OfficeBig_Rollershutter_Tilt.state as DecimalType).intValue
            val newTilt = Math::max(0, currentTilt - 10)
            OfficeBig_Rollershutter_Tilt.sendCommand(newTilt)
            logInfo("AqaraZorina", "  → Tilt " + currentTilt + " → " + newTilt + " (mehr offen)")
        }
        case "single_right": {
            val currentTilt = (OfficeBig_Rollershutter_Tilt.state as DecimalType).intValue
            val newTilt = Math::min(100, currentTilt + 10)
            OfficeBig_Rollershutter_Tilt.sendCommand(newTilt)
            logInfo("AqaraZorina", "  → Tilt " + currentTilt + " → " + newTilt + " (mehr zu)")
        }
        case "hold_left": {
            if (movingState == ON) {
                OfficeBig_Rollershutter.sendCommand(StopMoveType.STOP)
                OfficeBig_Rollershutter_Moving.postUpdate(OFF)
                if (OfficeBig_Rollershutter_MovingTimer !== null) {
                    OfficeBig_Rollershutter_MovingTimer.cancel()
                    OfficeBig_Rollershutter_MovingTimer = null
                }
                logInfo("AqaraZorina", "  → STOP (war in Bewegung)")
            } else {
                OfficeBig_Rollershutter.sendCommand(UpDownType.UP)
                OfficeBig_Rollershutter_Moving.postUpdate(ON)
                if (OfficeBig_Rollershutter_MovingTimer !== null) OfficeBig_Rollershutter_MovingTimer.cancel()
                OfficeBig_Rollershutter_MovingTimer = createTimer(now.plusSeconds(40)) [|
                    OfficeBig_Rollershutter_Moving.postUpdate(OFF)
                    logInfo("AqaraZorina", "  Moving-Timeout — Flag zurückgesetzt")
                ]
                logInfo("AqaraZorina", "  → UP")
            }
        }
        case "hold_right": {
            if (movingState == ON) {
                OfficeBig_Rollershutter.sendCommand(StopMoveType.STOP)
                OfficeBig_Rollershutter_Moving.postUpdate(OFF)
                if (OfficeBig_Rollershutter_MovingTimer !== null) {
                    OfficeBig_Rollershutter_MovingTimer.cancel()
                    OfficeBig_Rollershutter_MovingTimer = null
                }
                logInfo("AqaraZorina", "  → STOP (war in Bewegung)")
            } else {
                OfficeBig_Rollershutter.sendCommand(UpDownType.DOWN)
                OfficeBig_Rollershutter_Moving.postUpdate(ON)
                if (OfficeBig_Rollershutter_MovingTimer !== null) OfficeBig_Rollershutter_MovingTimer.cancel()
                OfficeBig_Rollershutter_MovingTimer = createTimer(now.plusSeconds(40)) [|
                    OfficeBig_Rollershutter_Moving.postUpdate(OFF)
                    logInfo("AqaraZorina", "  Moving-Timeout — Flag zurückgesetzt")
                ]
                logInfo("AqaraZorina", "  → DOWN")
            }
        }
        default: {
            logInfo("AqaraZorina", "  → Action unbekannt, ignoriert")
        }
    }
end
