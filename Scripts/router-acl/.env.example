# Router ACL Controller — configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Router access ─────────────────────────────────────────────────────────────
ROUTER_URL=http://10.0.0.138
ROUTER_USERNAME=admin
ROUTER_PASSWORD=

# ── ACL API paths (ZTE A1 WLAN Box defaults — should not need changing) ───────
# WLAN Advanced page — must be loaded before each ACL API call (sets server-side context)
ROUTER_WLAN_ADV_PATH=/getpage.lua?pid=123&nextpage=Localnet_WlanAdvanced_t.lp&Menu3Location=0
ROUTER_ACL_API_PATH=/common_page/Localnet_WlanAdvanced_MACFilterACLPolicy_lua.lua
ROUTER_ACL_ENABLE_VALUE=Allow
ROUTER_ACL_DISABLE_VALUE=Disabled
