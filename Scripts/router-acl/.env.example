# Router ACL Controller — configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Router access ─────────────────────────────────────────────────────────────
ROUTER_URL=http://10.0.0.138
ROUTER_USERNAME=admin
ROUTER_PASSWORD=

# ── Login form (run --probe to discover the correct field names) ───────────────
# Path the login form POSTs to (default works for many ZTE models)
ROUTER_LOGIN_PATH=/
# Form field names for username and password
ROUTER_LOGIN_USER_FIELD=loginUsername
ROUTER_LOGIN_PASS_FIELD=loginPassword

# ── WLAN Advanced page ────────────────────────────────────────────────────────
# URL path to the WLAN Advanced settings page
ROUTER_WLAN_ADV_PATH=/html/advance/wlanAdvance.html

# ── MAC ACL form field ────────────────────────────────────────────────────────
# Name of the HTML form field that controls the MAC filter mode
ROUTER_ACL_FIELD=MACFilterMode
# Value that means "ACL enabled" (typically 1)
ROUTER_ACL_ENABLE_VALUE=1
# Value that means "ACL disabled" (typically 0)
ROUTER_ACL_DISABLE_VALUE=0
# URL path the form POSTs to (leave empty to auto-detect from form action)
ROUTER_ACL_SUBMIT_PATH=
