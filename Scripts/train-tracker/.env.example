# Train Route Configuration
# Use exact station names as shown on ÖBB website (e.g., "Wien Hbf", "Salzburg Hbf", "Graz Hbf")
ORIGIN_STATION=Wien Hbf
DESTINATION_STATION=Salzburg Hbf
# Scheduled departure time in HH:MM format (24-hour)
SCHEDULED_TIME=08:15

# Optional Settings
# Maximum number of train changes allowed (0 = direct only, 1 = one transfer, etc.)
MAX_TRAIN_CHANGES=0

# How far ahead (in minutes) to search for departures (deprecated - not used with new API)
CHECK_AHEAD_MINUTES=120

# Note: OpenHAB configuration (station names, scheduled time, max changes) is now
# configured directly in the OpenHAB rules file (openhab/trains.rules).
# This .env file is optional and only used when running the script manually
# for testing purposes.
